{
    "server": {
        "port": 8080,
        "listen_ip": "0.0.0.0",
        "max_connections": 1024
    },
    "storage": {
        "data_dir": "data",
        "db_path": "asycdisk.db"
    },
    "limits": {
        "upload_kbps": 1000,
        "download_kbps": 1000
    },
    "security": {
        "encryption_enabled": true
    },
    "performance": {
        "read_buffer_size": 131072
    }
}